{
    "manifest_version": 3,
    "name": "MS LearnFlow",
    "description": "Export selected units from Microsoft Learn modules as a single PDF.",
    "version": "0.1.0",
    "permissions": [
        "activeTab",
        "scripting",
        "tabs",
        "storage",
        "offscreen",
        "downloads"
    ],
    "host_permissions": [
        "https://learn.microsoft.com/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "MS LearnFlow",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}